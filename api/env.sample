DATABASE_URL="postgresql://itera:itera@localhost:5432/itera?schema=public"
PORT=3000

# Clerk (backend verification of frontend JWT)
CLERK_SECRET_KEY="sk_test_..."
# Origins allowed for session token (azp claim). Comma-separated. Required for custom backend.
# Example: http://localhost:3001 (frontend dev), https://your-app.com (production)
CLERK_AUTHORIZED_PARTIES="http://localhost:3001"
# Clerk webhook (Svix signing secret – see Clerk Dashboard > Webhooks > Signing Secret)
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# App dashboard URL (for email-verified template CTA)
APP_DASHBOARD_URL="https://app.maximizeenfermagem.com.br"

# xAI Grok API key (for feedback, recommendations, exercises)
XAI_API_KEY=""

# OpenAI API key (for study explanations - GPT-4.1 mini)
OPENAI_API_KEY=""

# Nanonets Document Extraction API key (PDF to Markdown)
NANONETS_API_KEY=""

# Google Cloud Storage (imagens do enunciado das questões)
# Quem faz upload é a API (com as credenciais abaixo); só usuários autenticados da app podem chamar o endpoint.
GCS_BUCKET_NAME=""
# ID do projeto no GCP (opcional; o JSON da service account já costuma trazer; use se der erro de credentials).
GCP_PROJECT_ID=""
# Credenciais para a API escrever no bucket (obrigatório em local).
# "Could not load the default credentials" = defina esta variável com o caminho absoluto ao JSON da service account.
# Crie uma service account no Console GCP, dê o papel "Storage Object Creator" no bucket, baixe o JSON e aponte aqui.
# GCP (Cloud Run etc.): não defina; o ambiente já fornece credenciais.
GOOGLE_APPLICATION_CREDENTIALS="/caminho/absoluto/para/service-account.json"
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# O bucket deve permitir leitura pública dos objetos (para as URLs retornadas funcionarem).

GOOGLE_APPLICATION_CREDENTIALS=""

# Stripe (assinaturas)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# URL do frontend (para success/cancel do Checkout). Opcional; default http://localhost:3001
FRONTEND_URL="http://localhost:3001"

# URL do Next.js (landing/concursos). Usado para revalidação sob demanda quando ExamBase é alterado.
NEXTJS_URL="http://localhost:3002"
# Secret compartilhado com o Next.js para validar chamadas de revalidação.
REVALIDATE_SECRET=""

# Price IDs dos planos (criar no dashboard do Stripe: Products → criar 3 produtos,
# cada um com 1 preço mensal e 1 anual; copiar os IDs "price_xxx" para cá).
# Essencial
STRIPE_PRICE_ESSENCIAL_MONTHLY="price_..."
STRIPE_PRICE_ESSENCIAL_YEARLY="price_..."
# Estratégico
STRIPE_PRICE_ESTRATEGICO_MONTHLY="price_..."
STRIPE_PRICE_ESTRATEGICO_YEARLY="price_..."
# Elite
STRIPE_PRICE_ELITE_MONTHLY="price_..."
STRIPE_PRICE_ELITE_YEARLY="price_..."

# Redis (BullMQ - fila de emails)
# Opção 1 (recomendado): URL completa. No Render, use a Internal Redis URL.
REDIS_URL="redis://localhost:6379"
# Opção 2 (local): host/port/password separados (usado quando REDIS_URL não está definida)
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""

# Resend (emails transacionais)
RESEND_API_KEY_PROD="re_..."
# Default sender (optional; fallback: Maximize Enfermagem <equipe@mail.maximizeenfermagem.com.br>)
EMAIL_FROM="Maximize Enfermagem <equipe@mail.maximizeenfermagem.com.br>"

# PostHog (eventos autoritativos de exam/training vindos do backend).
# Usar a MESMA chave do projeto "maximize-app" que o web-react usa (VITE_POSTHOG_KEY).
POSTHOG_KEY=""
POSTHOG_HOST="https://eu.i.posthog.com"

# Meta Conversions API (CAPI) — espelho server-side do Meta Pixel.
# Quando alguém completa o wizard em /diagnostico e dá opt-in marketing, o
# backend manda o evento `Lead` direto pra Graph API do Meta com o mesmo
# event_id que o Pixel disparou no browser. Meta deduplica os dois canais
# → 1 conversão real, com match quality bem maior.
# Por quê: adblocker + iOS 14 ATT bloqueiam 30-50% dos eventos do Pixel
# sozinho; CAPI recupera isso e reduz o CPL dos anúncios.
# Sem essas envs, MetaConversionsService loga warn no boot e vira no-op
# silencioso — submit do diagnóstico continua funcionando normal, só não
# espelha o evento pro Meta.
# Refs: vibe-coding/2026-05-diagnostico-edital.md §8 + src/meta-conversions/

# Pixel ID / Dataset ID — mesmo valor de NEXT_PUBLIC_META_PIXEL_ID no nextjs.
# Endereço da "caixa postal" onde Pixel (browser) e CAPI (server) deixam eventos.
# Encontra em: Events Manager → Datasets → seu dataset → ID na barra do topo.
META_PIXEL_ID=""
# Access token gerado por um System User no Business Manager.
# Como gerar: Business Settings → System Users → criar um (role Admin) → Add
# Assets (Datasets + App) → Generate New Token, scopes ads_management +
# business_management, expiration "Never". Token formato EAAB.../EAAT...
META_CAPI_ACCESS_TOKEN=""
# Opcional. Quando setado, todos os eventos CAPI ganham `test_event_code` no
# payload — Meta os exibe na aba "Test events" do dataset em segundos (em vez
# de horas no relatório Overview). Útil em dev/staging; deixa vazio em prod.
# Encontra em: Events Manager → seu dataset → aba Test events → "Test event code".
META_TEST_EVENT_CODE=""