{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@domain/(.*)$": "<rootDir>/../../domain/$1"
  },
  "setupFiles": ["<rootDir>/e2e-env.ts"],
  "globalSetup": "<rootDir>/global-setup.ts",
  "testTimeout": 30000,
  "maxWorkers": 1
}
